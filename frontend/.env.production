# This file is used ONLY when you run: npm run build
# It tells the React app where to send API requests in production.
#
# VITE_API_URL = the public URL of your Django backend on Azure App Service
# Format: https://<your-app-service-name>.azurewebsites.net/api
#
# Our backend app name is "student-details", so the URL is:
VITE_API_URL=https://student-details.azurewebsites.net/api
